<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">
         
	<servlet>
    <servlet-name>recordInsert</servlet-name>
    <servlet-class>MedicalRecord.EnterRecordServlet</servlet-class>
	</servlet>

	<servlet-mapping>
    <servlet-name>recordInsert</servlet-name>
    <url-pattern>/EnterRecordServlet</url-pattern>
	</servlet-mapping>
	
	
	
	<servlet>
    <servlet-name>recordSearch</servlet-name>
    <servlet-class>MedicalRecord.SearchServlet</servlet-class>
	</servlet>

	<servlet-mapping>
    <servlet-name>recordSearch</servlet-name>
    <url-pattern>/SearchServlet</url-pattern>
	</servlet-mapping>
	
	
	
	<servlet>
    <servlet-name>recordUpdate</servlet-name>
    <servlet-class>MedicalRecord.RecordUpdateServlet</servlet-class>
	</servlet>

	<servlet-mapping>
    <servlet-name>recordUpdate</servlet-name>
    <url-pattern>/RecordUpdateServlet</url-pattern>
	</servlet-mapping>
	
	<servlet>
    <servlet-name>recordDelete</servlet-name>
    <servlet-class>MedicalRecord.DeleteRecordServlet</servlet-class>
	</servlet>

	<servlet-mapping>
    <servlet-name>recordDelete</servlet-name>
    <url-pattern>/DeleteRecordServlet</url-pattern>
	</servlet-mapping>

        
</web-app>